<xml>

<pragma once="true" />

<set name="id" value="com.byrobin.facebookads" />

<error value="The ${id} extension only provides native code for iOS" unless="ios" />

<files id="${id}-dependencies">
  <depend files="hxcpp-depends" />
  <depend name="${this_dir}/Build.xml" dateOnly="true" />
  <depend name="${this_dir}/include/HeyzapEx.h" />
</files>

<files id="${id}-ios" dir="${this_dir}">
  <depend files="${id}-dependencies" />
  <cache value="1" project="${id}" asLibrary="true" />
  <compilerflag value="-F../frameworks"/>
  <file name="common/ExternalInterface.cpp" />
  <file name="iphone/FBBannerController.mm"/>
  <file name="iphone/FBMediumRectController.mm"/>
  <file name="iphone/FBInterstitialController.mm"/>
</files>

<target id="haxe">
  <files id="com.byrobin.facebookads-ios" if="ios" />
</target>

<unset name="id" />

</xml>
